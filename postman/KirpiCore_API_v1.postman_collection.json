{
  "info": {
    "_postman_id": "6f1f3d96-2b6b-4e8f-b1df-6f8fb73214f7",
    "name": "KirpiCore API v1",
    "description": "KirpiCore REST API v1 test koleksiyonu. Once auth/token ile token alin, sonra me ve users endpointlerini cagirın.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://core.kirpinetwork.com"
    },
    {
      "key": "email",
      "value": "admin@kirpi.local"
    },
    {
      "key": "password",
      "value": "123456"
    },
    {
      "key": "token_name",
      "value": "postman"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "page",
      "value": "1"
    },
    {
      "key": "per_page",
      "value": "20"
    }
  ],
  "item": [
    {
      "name": "Auth - Create Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"token_name\": \"{{token_name}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/auth/token",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "token"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "pm.test('Token exists', function () {",
              "    pm.expect(jsonData.data.access_token).to.be.a('string').and.not.empty;",
              "});",
              "",
              "pm.collectionVariables.set('access_token', jsonData.data.access_token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Me - Current User",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/me",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "me"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "pm.test('Current user exists', function () {",
              "    pm.expect(jsonData.data.user).to.be.an('object');",
              "    pm.expect(jsonData.data.user.email).to.be.a('string');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Users - List",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/users?page={{page}}&per_page={{per_page}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "users"
          ],
          "query": [
            {
              "key": "page",
              "value": "{{page}}"
            },
            {
              "key": "per_page",
              "value": "{{per_page}}"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "pm.test('Users list exists', function () {",
              "    pm.expect(jsonData.data.users).to.be.an('array');",
              "    pm.expect(jsonData.meta).to.be.an('object');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}

